draw = function() {
    cursor("default");
    if (logoTimer < 450) {
        logo();
        if (logoTimer === 450) {
            flash.reset("menu");
        }
        return;
    }
    switch(scene) {
        case "game":
            game();
            break;
        case "menu":
            menu();
            break;
        case "skins":
            skins();
            break;
        case "scores":
            scores();
            break;
        case "how":
            how();
            break;
        case "settings":
            settings();
            break;
        case "after":
            after();
            break;
    }
    flash.display();
    click = false;
};

