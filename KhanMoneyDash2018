        characters[this.num](this.x * width / 5 + width / 5, this.y * height / 5 + height / 5, characterSize, this.moveX, this.moveY);
    };
    
    Player.prototype.move = function(direc) {
        switch(direc) {
            case LEFT:
                if (this.x > 0) {
                    this.x --;
                }
                this.moveX = -7;
                this.moveY = 0;
                break;
            case RIGHT:
                if (this.x < 3) {
                    this.x ++;
                }
                this.moveX = 7;
                this.moveY = 0;
                break;
            case UP:
                if (this.y > 0) {
                    this.y --;
                }
                this.moveY = -7;
                this.moveX = 0;
                break;
            case DOWN:
                if (this.y < 3) {
                    this.y ++;
                }
                this.moveY = 7;
                this.moveX = 0;
                break;
        }
    };
