keyPressed = function() {
    if (scene === "game" && countdown.done()) {
        player.move(keyCode);
    }
};

mouseDragged = function() {
    if (scene === "scores" && scoresList.length > 15) {
        
        scroll += mouseY - pmouseY;
    }
    scroll = constrain(scroll, -scoresList.length * 38 + 600, 0);
};

mouseScrolled = function() {
    /* jshint noarg : false */
    try {
        if (scene === "scores" && scoresList.length > 15) {
            arguments.callee.caller.arguments[0].preventDefault();
            scroll += mouseScroll * 20;
        }
    } catch (e) {}
    scroll = constrain(scroll, -scoresList.length * 38 + 600, 0);
};
