var info = {
    txt : [255, 0], timer : 250, curTxt : 0, 
    reset : function() {
        this.timer = 250;
        this.curTxt ++;
        this.curTxt %= this.txt.length;
    }, act : function() {
        if (this.txt[(this.curTxt + 1) % this.txt.length] < 255) {
            this.txt[(this.curTxt + 1) % this.txt.length] += 10;
        }
        if (this.txt[this.curTxt] > 0) {
            this.txt[this.curTxt] -= 10;
        }
        this.timer --;
        if (this.timer < 1) {
            this.reset();
