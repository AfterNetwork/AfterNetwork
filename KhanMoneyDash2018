        diamonds.push({x : random(0, 600), y : random(0, 600), size : random(50, 80), vel : random(5, 10)});
    }
    var logoNum = 1;
    var logoTimer = 0;
    
    var bounceText = function(x, y, string, list, vel) {
        x -= textWidth(string) / 2;
        for (var i = 0; i < string.length; i++) {
            if (vel[i] >= 0 || list[i] > 60) {
                list[i] += vel[i];
            } else {
                list[i] = 60;
            }
            
            textFont(f4, list[i]);
            text(string[i], x - (string[i] === "r" ? 9 : 0), y);
            textFont(f4, 60);
            x += textWidth(string[i]);
        }
    };
    
    var GGlogo = function(x, y, size) {
        noStroke();
        fill(255, 255, 255, 100);
        pushMatrix();
        translate(x + 5, y + 5);
        scale(size / 600, size / 600);
        beginShape();
        vertex(-270, 20);
        bezierVertex(-600, 250, -700, 600, -50, 600);
        vertex(-125, 400);
        vertex(-255, 480);
        bezierVertex(-305, 430, -395, 280, -205, 180);
        endShape();
        beginShape();
        vertex(270, 20);
        bezierVertex(600, 250, 700, 600, 50, 600);
        vertex(125, 400);
        vertex(255, 480);
        bezierVertex(305, 430, 395, 280, 205, 180);
        endShape();
        arc(0, 600, 1200, 1300, 249, 291);
        popMatrix();    
    
        fill(0, 200, 0);
        pushMatrix();
        translate(x, y);
        scale(size / 600, size / 600);
        beginShape();
        vertex(-270, 20);
        bezierVertex(-600, 250, -700, 600, -50, 600);
        vertex(-125, 400);
        vertex(-255, 480);
        bezierVertex(-305, 430, -395, 280, -205, 180);
        endShape();
        beginShape();
        vertex(270, 20);
        bezierVertex(600, 250, 700, 600, 50, 600);
        vertex(125, 400);
        vertex(255, 480);
        bezierVertex(305, 430, 395, 280, 205, 180);
        endShape();
        arc(0, 600, 1200, 1300, 249, 291);
        popMatrix();
    };
    
    var logo = function() {
        noStroke();
        logoTimer ++;
        background(100, 100, 100);
        for (var i = 0; i < diamonds.length; i++) {
            fill(50, 50, 50);
            quad(diamonds[i].x, diamonds[i].y, diamonds[i].x + diamonds[i].size / 2, diamonds[i].y + diamonds[i].size, diamonds[i].x, diamonds[i].y + diamonds[i].size * 2, diamonds[i].x - diamonds[i].size / 2, diamonds[i].y + diamonds[i].size);
            if (diamonds[i].size > 70) {
                fill(100, 100, 100);
                quad(diamonds[i].x, diamonds[i].y + diamonds[i].size / 2, diamonds[i].x + diamonds[i].size / 4, diamonds[i].y + diamonds[i].size, diamonds[i].x, diamonds[i].y + diamonds[i].size * 1.5, diamonds[i].x - diamonds[i].size / 4, diamonds[i].y + diamonds[i].size);
            }
            diamonds[i].y += diamonds[i].vel;
            if (diamonds[i].y > 600) {
                diamonds[i].y = -diamonds[i].size * 2;
                diamonds[i].x = random(0, 600);
            }
        }
        
        textAlign(CENTER, CENTER);
        fill(0, 200, 0);
        bounceText(323, 500, logoText, logoSize, logoVel);
        for (var i = 0; i < logoNum; i++) {
            if (logoSize[i] < 60) {
                if (logoVel[i] >= 0) {
                    logoVel[i] += 0.5;
                }
            } else {
                logoVel[i] -= 0.5;
            }
        }
        if (frameCount % 10 === 0) {
            logoNum ++;
        }
        GGlogo(300, 200, 200);
        if (click) {
            logoTimer = 450;
            click = false;
        }
    };
